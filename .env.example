# GhostMeter Environment Variables
# Copy this file to .env.local and fill in your values

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GhostMeter

# Analytics (Optional - for production)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Feature Flags
NEXT_PUBLIC_ENABLE_PREMIUM=true
NEXT_PUBLIC_MAX_FREE_ANALYSES=3

# Rate Limiting (per day)
RATE_LIMIT_MAX=3

# AI Configuration (automatically provided by z-ai-web-dev-sdk)
# No additional configuration needed for the AI SDK
